# Generate a 32+ byte secret before first run, for example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="generate-a-long-random-secret-before-running"
NEXTAUTH_SECRET="generate-a-long-random-secret-before-running"
# Project standard local port for this workspace.
NEXTAUTH_URL="http://localhost:3001"
ADMIN_EMAIL="admin@gyokurinken.local"
ADMIN_PASSWORD="ChangeMe-2026!"
ADMIN_NAME="Gyokurinken Admin"
ADMIN_ROLE="super_admin"
ADMIN_NOTIFY_EMAIL="admin@gyokurinken.local"
