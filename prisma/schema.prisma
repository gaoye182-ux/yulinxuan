generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  super_admin
  admin
  editor
  viewer
}

enum ContentStatus {
  draft
  published
  archived
}

enum PriceDisplay {
  show
  hidden
  inquiry
}

enum RequestStatus {
  unread
  in_progress
  replied
  completed
  rejected
  archived
}

model AdminUser {
  id                BigInt    @id @default(autoincrement())
  email             String    @unique @db.VarChar(255)
  passwordHash      String    @map("password_hash")
  name              String?   @db.VarChar(100)
  role              AdminRole @default(editor)
  avatar            String?
  totpSecret        String?   @map("totp_secret")
  totpEnabled       Boolean   @default(false) @map("totp_enabled")
  totpVerifiedAt    DateTime? @map("totp_verified_at") @db.Timestamptz(6)
  totpBackupCodes   String[]  @default([]) @map("totp_backup_codes")
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz(6)
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lastFailedLoginAt DateTime? @map("last_failed_login_at") @db.Timestamptz(6)
  lockedUntil       DateTime? @map("locked_until") @db.Timestamptz(6)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  blogPosts BlogPost[]
  media     Media[]
  auditLogs AuditLog[]

  @@map("admin_users")
}

model Category {
  id           BigInt   @id @default(autoincrement())
  slug         String   @unique @db.VarChar(100)
  name         Json
  description  Json?
  parentId     BigInt?  @map("parent_id")
  coverMediaId BigInt?  @map("cover_media_id")
  isActive     Boolean  @default(true) @map("is_active")
  showOnHome   Boolean  @default(true) @map("show_on_home")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryHierarchy")
  coverMedia Media?     @relation(fields: [coverMediaId], references: [id])
  items      Item[]

  @@map("categories")
}

model Item {
  id              BigInt        @id @default(autoincrement())
  slug            String        @unique @db.VarChar(255)
  name            Json
  description     Json?
  era             Json?
  origin          Json?
  artist          String?       @db.VarChar(255)
  dimensions      String?       @db.VarChar(255)
  weight          String?       @db.VarChar(100)
  condition       Json?
  price           Decimal?      @db.Decimal(12, 0)
  currency        String        @default("JPY") @db.VarChar(3)
  priceDisplay    PriceDisplay  @default(inquiry) @map("price_display")
  categoryId      BigInt?       @map("category_id")
  status          ContentStatus @default(draft)
  publishedAt     DateTime?     @map("published_at") @db.Timestamptz(6)
  isNew           Boolean       @default(false) @map("is_new")
  isFeatured      Boolean       @default(false) @map("is_featured")
  showOnHome      Boolean       @default(false) @map("show_on_home")
  sortOrder       Int           @default(0) @map("sort_order")
  viewCount       Int           @default(0) @map("view_count")
  metaTitle       Json?         @map("meta_title")
  metaDescription Json?         @map("meta_description")
  ogImage         String?       @map("og_image")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(6)

  category Category?         @relation(fields: [categoryId], references: [id])
  images   ItemImage[]
  tags     ItemTagRelation[]

  @@index([status, categoryId])
  @@map("items")
}

model ItemImage {
  id        BigInt   @id @default(autoincrement())
  itemId    BigInt   @map("item_id")
  mediaId   BigInt?  @map("media_id")
  url       String
  urlWebp   String?  @map("url_webp")
  urlThumb  String?  @map("url_thumb")
  altText   Json?    @map("alt_text")
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  item  Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  media Media? @relation(fields: [mediaId], references: [id])

  @@map("item_images")
}

model Tag {
  id        BigInt   @id @default(autoincrement())
  name      Json
  slug      String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  items ItemTagRelation[]

  @@map("tags")
}

model ItemTagRelation {
  itemId BigInt @map("item_id")
  tagId  BigInt @map("tag_id")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@map("item_tag_relations")
}

model BlogPost {
  id              BigInt        @id @default(autoincrement())
  slug            String        @unique @db.VarChar(255)
  title           Json
  excerpt         Json?
  content         Json?
  coverMediaId    BigInt?       @map("cover_media_id")
  authorId        BigInt?       @map("author_id")
  category        String?       @db.VarChar(100)
  tags            String[]
  status          ContentStatus @default(draft)
  isFeatured      Boolean       @default(false) @map("is_featured")
  publishedAt     DateTime?     @map("published_at") @db.Timestamptz(6)
  metaTitle       Json?         @map("meta_title")
  metaDescription Json?         @map("meta_description")
  ogImage         String?       @map("og_image")
  viewCount       Int           @default(0) @map("view_count")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  author     AdminUser? @relation(fields: [authorId], references: [id])
  coverMedia Media?     @relation(fields: [coverMediaId], references: [id])

  @@index([status, publishedAt])
  @@map("blog_posts")
}

model News {
  id              BigInt        @id @default(autoincrement())
  slug            String        @unique @db.VarChar(255)
  title           Json
  content         Json?
  type            String?       @db.VarChar(50)
  tags            String[]
  status          ContentStatus @default(draft)
  isFeatured      Boolean       @default(false) @map("is_featured")
  publishedAt     DateTime?     @map("published_at") @db.Timestamptz(6)
  metaTitle       Json?         @map("meta_title")
  metaDescription Json?         @map("meta_description")
  ogImage         String?       @map("og_image")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, publishedAt])
  @@map("news")
}

model AppraisalRequest {
  id            BigInt        @id @default(autoincrement())
  requestNo     String        @unique @map("request_no") @db.VarChar(32)
  type          String        @db.VarChar(30)
  name          String        @db.VarChar(100)
  email         String        @db.VarChar(255)
  phone         String?       @db.VarChar(40)
  region        String?       @db.VarChar(100)
  itemCategory  String?       @map("item_category") @db.VarChar(100)
  description   String?
  preferredDate DateTime?     @map("preferred_date") @db.Date
  images        String[]
  status        RequestStatus @default(unread)
  adminNote     String?       @map("admin_note")
  lang          String        @default("ja") @db.VarChar(5)
  ipAddress     String?       @map("ip_address")
  userAgent     String?       @map("user_agent")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("appraisal_requests")
}

model ContactMessage {
  id        BigInt        @id @default(autoincrement())
  name      String        @db.VarChar(100)
  email     String        @db.VarChar(255)
  phone     String?       @db.VarChar(40)
  category  String?       @db.VarChar(50)
  message   String
  status    RequestStatus @default(unread)
  adminNote String?       @map("admin_note")
  replyNote String?       @map("reply_note")
  lang      String        @default("ja") @db.VarChar(5)
  ipAddress String?       @map("ip_address")
  userAgent String?       @map("user_agent")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("contact_messages")
}

model PageBlock {
  id        BigInt   @id @default(autoincrement())
  pageKey   String   @map("page_key") @db.VarChar(100)
  blockKey  String   @map("block_key") @db.VarChar(100)
  content   Json
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([pageKey, blockKey])
  @@map("page_blocks")
}

model Media {
  id           BigInt   @id @default(autoincrement())
  filename     String   @db.VarChar(255)
  originalName String?  @map("original_name") @db.VarChar(255)
  url          String
  urlWebp      String?  @map("url_webp")
  urlThumb     String?  @map("url_thumb")
  mimeType     String?  @map("mime_type") @db.VarChar(100)
  fileSize     Int?     @map("file_size")
  width        Int?
  height       Int?
  altText      Json?    @map("alt_text")
  uploadedById BigInt?  @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  uploadedBy AdminUser?  @relation(fields: [uploadedById], references: [id])
  categories Category[]
  itemImages ItemImage[]
  blogPosts  BlogPost[]

  @@map("media")
}

model SiteSetting {
  key       String   @id @db.VarChar(100)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("site_settings")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  adminUserId BigInt?  @map("admin_user_id")
  action      String   @db.VarChar(100)
  targetType  String?  @map("target_type") @db.VarChar(100)
  targetId    String?  @map("target_id") @db.VarChar(100)
  beforeData  Json?    @map("before_data")
  afterData   Json?    @map("after_data")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id])

  @@map("audit_logs")
}
